# Persistence mode: "memory" (default) or "postgres"
PERSISTENCE_BACKEND=memory

# Use either SUPABASE_DATABASE_URL or DATABASE_URL when PERSISTENCE_BACKEND=postgres
SUPABASE_DATABASE_URL=
DATABASE_URL=

# Auto-create required tables on startup when using Postgres
POSTGRES_AUTO_CREATE_SCHEMA=true

# JWT-only backend mode.
# Keep enabled in normal operation.
AUTH_REQUIRE_JWT_SIGNATURE_VERIFICATION=true

# Supabase project base URL (used to derive issuer and JWKS endpoint):
# issuer -> {SUPABASE_URL}/auth/v1
# jwks   -> {issuer}/.well-known/jwks.json
# Example: https://your-project-ref.supabase.co
# Do not include angle brackets in the actual value.
SUPABASE_URL=

# Optional explicit overrides. Leave blank to use SUPABASE_URL-derived values.
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_JWKS_URL=

# Supabase Auth audience for access tokens (typically "authenticated").
SUPABASE_JWT_AUDIENCE=authenticated

# Optional legacy signing mode support (HS256). If set, secret verification is used
# instead of JWKS verification.
SUPABASE_JWT_SECRET=

# JWT verification tuning.
SUPABASE_JWKS_CACHE_TTL_SECONDS=300
SUPABASE_JWKS_HTTP_TIMEOUT_SECONDS=5
SUPABASE_JWT_LEEWAY_SECONDS=30

# Comma-separated CORS origins for dashboard/extension clients.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Analysis provider selection.
# Default keeps deterministic provider active.
# Set ANALYSIS_PROVIDER_MODE=ai to enable AI-backed analysis provider path.
ANALYSIS_PROVIDER_MODE=deterministic

# AI provider kind (used when ANALYSIS_PROVIDER_MODE=ai).
# Supported values: gemini, openai_compatible
# Gemini is the intended default provider for this project.
ANALYSIS_AI_PROVIDER_KIND=gemini

# Gemini native provider settings.
ANALYSIS_GEMINI_API_KEY=
ANALYSIS_GEMINI_MODEL=gemini-2.0-flash
ANALYSIS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Generic OpenAI-compatible provider settings.
ANALYSIS_OPENAI_COMPATIBLE_API_KEY=
ANALYSIS_OPENAI_COMPATIBLE_MODEL=
ANALYSIS_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

# Legacy compatibility aliases (optional):
# ANALYSIS_AI_API_KEY
# ANALYSIS_AI_MODEL
# ANALYSIS_AI_BASE_URL

ANALYSIS_AI_TIMEOUT_SECONDS=20
ANALYSIS_AI_TEMPERATURE=0.1

# If true, runtime/provider errors on the AI path fall back to deterministic analysis.
ANALYSIS_AI_FALLBACK_TO_DETERMINISTIC=true

# Internal analysis execution mode seam.
# Current implementation supports sync only; unknown modes fall back to sync.
ANALYSIS_EXECUTION_MODE=sync

# Optional for local extension runtime testing:
# append your unpacked extension origin after loading it in Chrome if
# extension analysis requests are blocked by browser/backend CORS handling.
# Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,chrome-extension://abcdefghijklmnopabcdefghijklmnop
# Restart backend after changing this value.
