# Production environment configuration for Render deployment.
# Use this as a reference when populating the Render dashboard.
# Keep real values in Render env vars instead of committing them here.

# =============================================================================
# Persistence Configuration
# =============================================================================

# Use "postgres" for production (or "memory" for testing without DB)
PERSISTENCE_BACKEND=postgres

# Supabase Postgres connection string
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Get from: Supabase Dashboard -> Settings -> Database -> Connection string
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Optional: Use DATABASE_URL as fallback if SUPABASE_DATABASE_URL is not set
# DATABASE_URL=

# Auto-create tables on startup (set to false after initial deployment)
POSTGRES_AUTO_CREATE_SCHEMA=true

# =============================================================================
# Authentication Configuration
# =============================================================================

# Enable JWT signature verification in production
AUTH_REQUIRE_JWT_SIGNATURE_VERIFICATION=true

# Supabase project URL
# Example: https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT audience (typically "authenticated")
SUPABASE_JWT_AUDIENCE=authenticated

# JWT issuer (auto-derived from SUPABASE_URL if not set)
# SUPABASE_JWT_ISSUER=

# JWKS URL (auto-derived from issuer if not set)
# SUPABASE_JWT_JWKS_URL=

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated origins. Replace placeholders with your actual frontend URLs.
# Example: https://your-project.pages.dev,https://app.example.com
CORS_ALLOWED_ORIGINS=https://[YOUR-CLOUDFLARE-PAGES-URL]

# =============================================================================
# Analysis Provider Configuration (optional)
# =============================================================================

# Keep as "deterministic" for free/development, or set to "ai" for AI-backed analysis
ANALYSIS_PROVIDER_MODE=deterministic

# If using AI mode, specify provider kind: "gemini" or "openai_compatible"
# ANALYSIS_AI_PROVIDER_KIND=gemini

# Gemini configuration (if using AI mode)
# ANALYSIS_GEMINI_API_KEY=your-gemini-api-key
# ANALYSIS_GEMINI_MODEL=gemini-2.5-flash
# ANALYSIS_GEMINI_MAX_INPUT_TOKENS=250000
# ANALYSIS_GEMINI_ESTIMATED_CHARS_PER_TOKEN=3

# OpenAI-compatible configuration (if using AI mode)
# ANALYSIS_OPENAI_COMPATIBLE_API_KEY=your-api-key
# ANALYSIS_OPENAI_COMPATIBLE_MODEL=your-model
# ANALYSIS_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1

# Fallback to deterministic if AI fails (recommended)
# ANALYSIS_AI_FALLBACK_TO_DETERMINISTIC=true

# =============================================================================
# Execution Mode
# =============================================================================

# Keep as "sync" for MVP deployment
ANALYSIS_EXECUTION_MODE=sync

# =============================================================================
# Abuse Protection
# =============================================================================

# Coarse API protection against scraping and repeated automated requests
API_RATE_LIMIT_REQUESTS_PER_WINDOW=60
API_RATE_LIMIT_WINDOW_SECONDS=60

# Tighter write-side protection for agreement creation
AGREEMENT_CREATE_RATE_LIMIT_REQUESTS=10
AGREEMENT_CREATE_RATE_LIMIT_WINDOW_SECONDS=600

# Strict budgets for AI-backed or deterministic analysis generation endpoints
ANALYSIS_RATE_LIMIT_REQUESTS=5
ANALYSIS_RATE_LIMIT_WINDOW_SECONDS=300
ANALYSIS_HOURLY_RATE_LIMIT_REQUESTS=20
ANALYSIS_HOURLY_RATE_LIMIT_WINDOW_SECONDS=3600

# =============================================================================
# Application Environment
# =============================================================================

# Set to "production" for production deployments
APP_ENV=production
