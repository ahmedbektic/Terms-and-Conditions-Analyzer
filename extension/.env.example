# Optional extension build-time auth configuration.
# If unset, extension build falls back to frontend VITE_SUPABASE_* values.
#
# You can also override these at runtime using chrome.storage.local keys:
# - auth_supabase_url
# - auth_supabase_anon_key
# - api_base_url (backend API base URL override)
# - extraction_min_length (number > 0, optional extraction threshold override)
# Note: do not seed `auth_session` manually. Runtime auth writes session state
# after successful sign-in through popup/background flow.
#
# Anon key is safe for client use. Never put service-role keys in extension config.
# Google sign-in also requires Supabase allow-list entry:
# https://<extension-id>.chromiumapp.org/supabase-auth
# See docs/google-auth-setup-matrix.md.
#
# Optional extension API base URL override at build time.
# Resolution order for API base URL:
# 1) EXTENSION_API_BASE_URL (process env)
# 2) VITE_API_BASE_URL (process env)
# 3) EXTENSION_API_BASE_URL / VITE_API_BASE_URL in extension .env/.env.local
# 4) VITE_API_BASE_URL from frontend env files
# 5) fallback default: http://127.0.0.1:8000/api/v1
EXTENSION_API_BASE_URL=
EXTENSION_SUPABASE_URL=
EXTENSION_SUPABASE_ANON_KEY=
