{
  "manifest_version": 3,
  "name": "Terms & Conditions Analyzer Extension",
  "version": "0.1.0",
  "description": "SCRUM-9 browser extension scaffold for policy extraction and analysis orchestration.",
  "action": {
    "default_popup": "dist/popup/index.html",
    "default_title": "Terms & Conditions Analyzer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.service-worker.js"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.onrender.com/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
