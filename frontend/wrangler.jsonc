{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloud-terms-and-conditions-analyzer",
  "main": "./worker/index.ts",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
